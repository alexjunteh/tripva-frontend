{
  "journeys": [
    {
      "id": "landing-see-demo",
      "name": "Landing → 'See full demo' opens a real trip",
      "critical": true,
      "steps": [
        { "action": "goto", "url": "/?qa=1" },
        { "action": "wait", "ms": 2500 },
        { "action": "scroll", "to": "#demo" },
        { "action": "wait", "ms": 1200 },
        { "action": "eval", "js": "const a=document.querySelector('a[href*=\"trip.html?id=\"]'); if(a) location.href = a.href.replace('target=_blank','');" },
        { "action": "wait", "ms": 12000 }
      ],
      "assert": [
        { "url-matches": "/trip" },
        { "no-404-in-body": true },
        { "text-not-contains": "No trip found" },
        { "text-not-contains": "Trip not found" },
        { "js-true": "document.querySelectorAll('.tab-content.active').length > 0 || document.querySelectorAll('.nav-btn').length > 0" }
      ]
    },
    {
      "id": "more-menu-has-save",
      "name": "More menu on trip has Save, Upgrade, Calendar, Edit",
      "critical": true,
      "steps": [
        { "action": "goto", "url": "/trip?id=a2ba2994227e63956443c06529543317&qa=1" },
        { "action": "wait", "ms": 10000 },
        { "action": "eval", "js": "openMore(); true" },
        { "action": "wait", "ms": 1800 }
      ],
      "assert": [
        { "js-true": "document.getElementById('moreOverlay')?.classList.contains('open')" },
        { "js-true": "[...document.querySelectorAll('.more-action')].some(b => /Save trip/i.test(b.textContent))" },
        { "selector-exists": "#moreUpgradeBtn" },
        { "js-true": "[...document.querySelectorAll('.more-action')].some(b => /Calendar/i.test(b.textContent))" },
        { "js-true": "[...document.querySelectorAll('.more-action')].some(b => /Edit Trip/i.test(b.textContent))" }
      ]
    },
    {
      "id": "fab-no-overlap-more",
      "name": "FAB hidden when More menu open",
      "critical": true,
      "steps": [
        { "action": "goto", "url": "/trip?id=a2ba2994227e63956443c06529543317&qa=1" },
        { "action": "wait", "ms": 10000 },
        { "action": "eval", "js": "openMore(); true" },
        { "action": "wait", "ms": 2000 }
      ],
      "assert": [
        { "js-true": "(() => { const f=document.querySelector('.fab-main'); const cs=getComputedStyle(f); return parseFloat(cs.opacity) < 0.15 || cs.pointerEvents === 'none'; })()" }
      ]
    },
    {
      "id": "budget-tab-usable",
      "name": "Budget tab either renders rows or actionable empty state",
      "critical": true,
      "steps": [
        { "action": "goto", "url": "/trip?id=a2ba2994227e63956443c06529543317&qa=1" },
        { "action": "wait", "ms": 8000 },
        { "action": "eval", "js": "switchTab('budget'); true" },
        { "action": "wait", "ms": 1500 }
      ],
      "assert": [
        { "js-true": "(() => { const rows=document.querySelectorAll('.budget-row').length; const empty=document.getElementById('budgetEmpty'); const emptyVisible = empty && getComputedStyle(empty).display !== 'none'; if (rows>0) return true; if (emptyVisible && empty.querySelectorAll('button,a').length>0) return true; return false; })()" }
      ]
    },
    {
      "id": "packing-no-400",
      "name": "Packing modal loads without API 400",
      "critical": true,
      "steps": [
        { "action": "goto", "url": "/trip?id=a2ba2994227e63956443c06529543317&qa=1" },
        { "action": "wait", "ms": 8000 },
        { "action": "eval", "js": "openPackModal(); true" },
        { "action": "wait", "ms": 15000 }
      ],
      "assert": [
        { "text-not-contains": "API error" },
        { "text-not-contains": "Could not load" }
      ]
    },
    {
      "id": "mytrips-auth-paths",
      "name": "mytrips has Google + magic-link signin",
      "critical": true,
      "steps": [
        { "action": "goto", "url": "/mytrips?qa=1" },
        { "action": "wait", "ms": 3000 }
      ],
      "assert": [
        { "selector-exists": "#googleBtn" },
        { "selector-exists": "#authSendBtn" }
      ]
    },
    {
      "id": "tickets-no-meals",
      "name": "Tickets tab does not list meal items",
      "critical": false,
      "steps": [
        { "action": "goto", "url": "/trip?id=a2ba2994227e63956443c06529543317&qa=1" },
        { "action": "wait", "ms": 8000 },
        { "action": "eval", "js": "switchTab('tickets'); true" },
        { "action": "wait", "ms": 1500 }
      ],
      "assert": [
        { "js-true": "(() => { const tkts = [...document.querySelectorAll('.tkt-card, .ticket-card, [data-derived-ticket]')]; for (const t of tkts) { const txt = (t.innerText||'').toLowerCase(); if (/breakfast|dinner|lunch|café|cafe at/i.test(txt) && !/breakfast train|lunch bus/i.test(txt)) return false; } return true; })()" }
      ]
    },
    {
      "id": "plan-form-prefills",
      "name": "plan.html deep-link pre-fills dest + archetype",
      "critical": false,
      "steps": [
        { "action": "goto", "url": "/plan?dest=Tokyo&archetype=family&travelers=4&qa=1" },
        { "action": "wait", "ms": 2500 }
      ],
      "assert": [
        { "js-equals": "document.getElementById('f-dest').value", "expect": "Tokyo" },
        { "js-equals": "document.querySelector('.arch-pill.active')?.dataset.arch", "expect": "family" }
      ]
    },
    {
      "id": "days-tab-has-events",
      "name": "Days tab shows per-day timeline items (not empty)",
      "critical": true,
      "steps": [
        { "action": "goto", "url": "/trip?id=a2ba2994227e63956443c06529543317&qa=1" },
        { "action": "wait", "ms": 10000 },
        { "action": "eval", "js": "switchTab('days'); true" },
        { "action": "wait", "ms": 2000 }
      ],
      "assert": [
        { "js-true": "document.querySelectorAll('.day-big-card, .day-card, .day-pill').length > 0" },
        { "js-true": "(() => { const cards = [...document.querySelectorAll('.day-big-card')]; if (!cards.length) return false; const withEvents = cards.filter(c => { const n = parseInt((c.innerText.match(/(\\d+)\\s*events?/i)||[0,0])[1]); return n > 0 || c.querySelectorAll('.day-big-events').length > 0; }); return withEvents.length > 0; })()" }
      ]
    },
    {
      "id": "day-sheet-has-timeline",
      "name": "Opening Day sheet shows timeline items",
      "critical": true,
      "steps": [
        { "action": "goto", "url": "/trip?id=a2ba2994227e63956443c06529543317&qa=1" },
        { "action": "wait", "ms": 10000 },
        { "action": "eval", "js": "switchTab('days'); true" },
        { "action": "wait", "ms": 1500 },
        { "action": "eval", "js": "openDaySheet(0); true" },
        { "action": "wait", "ms": 1500 }
      ],
      "assert": [
        { "js-true": "document.getElementById('daySheetOverlay')?.classList.contains('open')" },
        { "js-true": "document.querySelectorAll('#sheetBody .tl-row, #sheetBody .timeline-item, #sheetBody .tl-item').length >= 1" }
      ]
    },
    {
      "id": "landing-all-destinations-resolve",
      "name": "All destination gallery tiles link to plan.html",
      "critical": false,
      "steps": [
        { "action": "goto", "url": "/?qa=1" },
        { "action": "wait", "ms": 2500 }
      ],
      "assert": [
        { "js-true": "document.querySelectorAll('a.dest-tile').length >= 6" }
      ]
    },
    {
      "id": "currency-chip-updates-hero",
      "name": "Budget FX chip flips hero totals to selected currency",
      "critical": true,
      "steps": [
        { "action": "goto", "url": "/trip?id=a2ba2994227e63956443c06529543317&qa=1" },
        { "action": "wait", "ms": 10000 },
        { "action": "eval", "js": "switchTab('budget'); true" },
        { "action": "wait", "ms": 1500 },
        { "action": "eval", "js": "onFxChange('EUR'); true" },
        { "action": "wait", "ms": 1000 }
      ],
      "assert": [
        { "js-true": "/€/.test(document.querySelector('.budget-hero-num')?.textContent||'')" },
        { "js-true": "document.querySelector('.fx-chip.active')?.dataset.cur === 'EUR'" }
      ]
    },
    {
      "id": "mark-booked-moves-row",
      "name": "Mark booked button flips row from pending to booked section",
      "critical": true,
      "steps": [
        { "action": "goto", "url": "/trip?id=a2ba2994227e63956443c06529543317&qa=1" },
        { "action": "wait", "ms": 10000 },
        { "action": "eval", "js": "switchTab('budget'); true" },
        { "action": "wait", "ms": 1500 }
      ],
      "assert": [
        { "js-true": "document.querySelectorAll('.budget-row.budget-pending button[onclick*=\"markBudgetBooked\"]').length >= 1" },
        { "js-true": "document.querySelectorAll('.budget-row.budget-pending button[onclick*=\"addBudgetBookingLink\"]').length >= 1" }
      ]
    },
    {
      "id": "mark-booked-actually-flips",
      "name": "Clicking Mark Booked reduces pending count + increases booked count (outcome test)",
      "critical": true,
      "steps": [
        { "action": "goto", "url": "/trip?id=a2ba2994227e63956443c06529543317&qa=1" },
        { "action": "wait", "ms": 10000 },
        { "action": "eval", "js": "switchTab('budget'); window.__pre = {pending: document.querySelectorAll('.budget-row.budget-pending').length, booked: document.querySelectorAll('.budget-row.budget-booked').length}; true" },
        { "action": "wait", "ms": 1000 },
        { "action": "eval", "js": "document.querySelector('.budget-row.budget-pending button[onclick*=\"markBudgetBooked\"]')?.click(); true" },
        { "action": "wait", "ms": 1500 }
      ],
      "assert": [
        { "js-true": "document.querySelectorAll('.budget-row.budget-pending').length < (window.__pre?.pending ?? 99)" },
        { "js-true": "document.querySelectorAll('.budget-row.budget-booked').length > (window.__pre?.booked ?? -1)" }
      ]
    },
    {
      "id": "currency-chip-hero-actually-changes",
      "name": "FX chip tap actually changes hero number (not just active state)",
      "critical": true,
      "steps": [
        { "action": "goto", "url": "/trip?id=a2ba2994227e63956443c06529543317&qa=1" },
        { "action": "wait", "ms": 10000 },
        { "action": "eval", "js": "switchTab('budget'); true" },
        { "action": "wait", "ms": 1500 },
        { "action": "eval", "js": "window.__heroBefore = document.querySelector('.budget-hero-num')?.textContent || ''; onFxChange('JPY'); true" },
        { "action": "wait", "ms": 1000 }
      ],
      "assert": [
        { "js-true": "/¥/.test(document.querySelector('.budget-hero-num')?.textContent||'')" },
        { "js-true": "document.querySelector('.budget-hero-num')?.textContent !== window.__heroBefore" }
      ]
    },
    {
      "id": "ai-example-chip-fills-input",
      "name": "Clicking an AI example chip drops it into the input (outcome test)",
      "critical": false,
      "steps": [
        { "action": "goto", "url": "/trip?id=a2ba2994227e63956443c06529543317&qa=1" },
        { "action": "wait", "ms": 10000 },
        { "action": "eval", "js": "toggleAiChat(); true" },
        { "action": "wait", "ms": 1000 },
        { "action": "eval", "js": "document.querySelector('#aiChatMsgs .ai-examples button')?.click(); true" },
        { "action": "wait", "ms": 300 }
      ],
      "assert": [
        { "js-true": "(document.getElementById('aiChatInput')?.value || '').length > 5" }
      ]
    },
    {
      "id": "day-sheet-event-count-matches-backend",
      "name": "Day sheet timeline items == backend timeline length (data contract)",
      "critical": true,
      "steps": [
        { "action": "goto", "url": "/trip?id=a2ba2994227e63956443c06529543317&qa=1" },
        { "action": "wait", "ms": 10000 },
        { "action": "eval", "js": "switchTab('days'); openDaySheet(0); true" },
        { "action": "wait", "ms": 1500 }
      ],
      "assert": [
        { "js-true": "(() => { const backendCount = (window.plan?.days?.[0]?.timeline || []).length; const rendered = document.querySelectorAll('#sheetBody .tl-row, #sheetBody .timeline-item, #sheetBody .tl-item').length; return backendCount === 0 || rendered === backendCount; })()" }
      ]
    },
    {
      "id": "budget-self-heal-when-missing",
      "name": "Plan with days but no budget triggers self-heal (fetches via /api/patch + renders)",
      "critical": false,
      "steps": [
        { "action": "goto", "url": "/" },
        { "action": "eval", "js": "sessionStorage.clear(); localStorage.setItem('tripva_plan', JSON.stringify({trip:{id:'heal-test-'+Date.now(),name:'Heal Test Rome',destination:'Rome',startDate:'2026-07-01',endDate:'2026-07-04',currency:'EUR'},days:[{day:1,date:'2026-07-01',title:'Arrive',timeline:[{time:'10:00',title:'Colosseum',detail:'Visit',type:'activity'}]}],hotels:[],tickets:[],urgent:[]})); true" },
        { "action": "goto", "url": "/trip.html" },
        { "action": "wait", "ms": 8000 },
        { "action": "eval", "js": "switchTab && switchTab('budget'); true" },
        { "action": "wait", "ms": 2000 }
      ],
      "assert": [
        { "js-true": "typeof window.healMissingBudget === 'function'" },
        { "js-true": "!!document.getElementById('budgetEmpty') === false || /Generating|No budget/.test(document.getElementById('budgetEmpty')?.textContent || '')" }
      ]
    },
    {
      "id": "calendar-export-reachable",
      "name": "Calendar (.ics) button present in More menu + Day sheet",
      "critical": false,
      "steps": [
        { "action": "goto", "url": "/trip?id=a2ba2994227e63956443c06529543317&qa=1" },
        { "action": "wait", "ms": 10000 },
        { "action": "eval", "js": "openMore(); true" },
        { "action": "wait", "ms": 1000 }
      ],
      "assert": [
        { "js-true": "[...document.querySelectorAll('.more-action')].some(b => /Calendar/i.test(b.textContent))" },
        { "js-true": "typeof window.exportTripIcs === 'function'" },
        { "js-true": "typeof window.exportDayIcs === 'function'" }
      ]
    },
    {
      "id": "plan-archetype-switch-conditional",
      "name": "Plan form switching archetypes reveals archetype-specific fields",
      "critical": true,
      "steps": [
        { "action": "goto", "url": "/plan?archetype=family&qa=1" },
        { "action": "wait", "ms": 2500 }
      ],
      "assert": [
        { "js-true": "document.querySelector('.arch-fields[data-arch=\"family\"]')?.classList.contains('active')" },
        { "js-true": "document.querySelectorAll('.child-age-input').length >= 1 || document.querySelectorAll('.child-ages-wrap').length >= 1" },
        { "js-true": "document.querySelector('.arch-fields[data-arch=\"couple\"]')?.classList.contains('active') === false" }
      ]
    },
    {
      "id": "plan-submit-validation",
      "name": "Plan submit without destination surfaces validation",
      "critical": false,
      "steps": [
        { "action": "goto", "url": "/plan?qa=1" },
        { "action": "wait", "ms": 2000 },
        { "action": "eval", "js": "document.getElementById('f-dest').value=''; try{submitTrip();}catch(e){} true" },
        { "action": "wait", "ms": 500 }
      ],
      "assert": [
        { "js-true": "document.getElementById('toast')?.classList?.contains('show') || /going|destination|required/i.test(document.getElementById('toast')?.textContent||'')" }
      ]
    },
    {
      "id": "reminders-button-present",
      "name": "🔔 Reminders button shows in More menu",
      "critical": false,
      "steps": [
        { "action": "goto", "url": "/trip?id=a2ba2994227e63956443c06529543317&qa=1" },
        { "action": "wait", "ms": 10000 },
        { "action": "eval", "js": "openMore(); true" },
        { "action": "wait", "ms": 800 }
      ],
      "assert": [
        { "js-true": "[...document.querySelectorAll('.more-item')].some(el => /Reminders/i.test(el.textContent))" },
        { "js-true": "typeof window.enableTripReminders === 'function'" }
      ]
    },
    {
      "id": "edit-trip-modal-opens",
      "name": "Edit Trip button opens modal with fields pre-filled from plan",
      "critical": false,
      "steps": [
        { "action": "goto", "url": "/trip?id=a2ba2994227e63956443c06529543317&qa=1" },
        { "action": "wait", "ms": 10000 },
        { "action": "eval", "js": "openEditModal(); true" },
        { "action": "wait", "ms": 800 }
      ],
      "assert": [
        { "js-true": "document.getElementById('editModal')?.classList.contains('open')" },
        { "js-true": "document.getElementById('editName')?.value?.length > 0" }
      ]
    },
    {
      "id": "upgrade-to-pro-graceful",
      "name": "Upgrade to Pro shows graceful 'not ready' toast (no Stripe env yet)",
      "critical": false,
      "steps": [
        { "action": "goto", "url": "/trip?id=a2ba2994227e63956443c06529543317&qa=1" },
        { "action": "wait", "ms": 10000 },
        { "action": "eval", "js": "window.__pollToasts = []; const el = document.getElementById('toast'); const mo = new MutationObserver(() => window.__pollToasts.push(el.textContent)); if (el) mo.observe(el, {childList:true, characterData:true, subtree:true}); localStorage.setItem('tripva_session', JSON.stringify({access_token:'fake',expires_at:Date.now()+3600000})); upgradeToPro(); true" },
        { "action": "wait", "ms": 3500 }
      ],
      "assert": [
        { "js-true": "(window.__pollToasts||[]).some(m => /not live yet|Pro plan|Opening checkout|Could not|Network/i.test(m||''))" }
      ]
    },
    {
      "id": "cold-viewer-banner-dismiss",
      "name": "Cold-viewer banner has dismissible close (regression guard)",
      "critical": false,
      "steps": [
        { "action": "goto", "url": "/trip?id=a2ba2994227e63956443c06529543317&qa=1" },
        { "action": "wait", "ms": 10000 },
        { "action": "eval", "js": "document.body.classList.add('viewer-mode'); const vb=document.getElementById('viewerBanner'); if(vb){vb.style.display='flex';} true" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "js": "dismissViewerBanner(); true" },
        { "action": "wait", "ms": 500 }
      ],
      "assert": [
        { "js-true": "getComputedStyle(document.getElementById('viewerBanner')).display === 'none'" }
      ]
    },
    {
      "id": "share-link-reachable",
      "name": "Share button in More menu triggers share flow",
      "critical": false,
      "steps": [
        { "action": "goto", "url": "/trip?id=a2ba2994227e63956443c06529543317&qa=1" },
        { "action": "wait", "ms": 10000 },
        { "action": "eval", "js": "openMore(); true" },
        { "action": "wait", "ms": 800 }
      ],
      "assert": [
        { "js-true": "[...document.querySelectorAll('.more-item')].some(el => /Share/i.test(el.textContent))" },
        { "js-true": "typeof shareTripLink === 'function'" }
      ]
    },
    {
      "id": "dest-gallery-carries-dest-param",
      "name": "Destination gallery tile URLs include dest= query param",
      "critical": false,
      "steps": [
        { "action": "goto", "url": "/?qa=1" },
        { "action": "wait", "ms": 2500 }
      ],
      "assert": [
        { "js-true": "[...document.querySelectorAll('a.dest-tile')].every(a => /[?&]dest=/.test(a.getAttribute('href')||''))" }
      ]
    },
    {
      "id": "sos-tab-has-content",
      "name": "SOS tab shows emergency info for the destination",
      "critical": false,
      "steps": [
        { "action": "goto", "url": "/trip?id=a2ba2994227e63956443c06529543317&qa=1" },
        { "action": "wait", "ms": 10000 },
        { "action": "eval", "js": "switchTab('sos'); true" },
        { "action": "wait", "ms": 1500 }
      ],
      "assert": [
        { "js-true": "document.querySelectorAll('#tab-sos .sos-number, #tab-sos a[href^=\"tel:\"], #tab-sos .sos-card, #tab-sos button').length >= 1" }
      ]
    },
    {
      "id": "ai-edit-works",
      "name": "AI Edit chat opens + example chips appear + input focusable",
      "critical": false,
      "steps": [
        { "action": "goto", "url": "/trip?id=a2ba2994227e63956443c06529543317&qa=1" },
        { "action": "wait", "ms": 10000 },
        { "action": "eval", "js": "toggleAiChat(); true" },
        { "action": "wait", "ms": 1200 }
      ],
      "assert": [
        { "js-true": "document.getElementById('aiChatBar')?.style.display === 'flex'" },
        { "js-true": "document.querySelectorAll('#aiChatMsgs .ai-examples button').length >= 4" },
        { "js-true": "!!document.getElementById('aiChatInput')" }
      ]
    },
    {
      "id": "tabs-all-switchable",
      "name": "All 5 bottom-nav tabs switch without error",
      "critical": true,
      "steps": [
        { "action": "goto", "url": "/trip?id=a2ba2994227e63956443c06529543317&qa=1" },
        { "action": "wait", "ms": 10000 }
      ],
      "assert": [
        { "js-true": "(() => { const tabs=['plan','days','tickets','budget','trip']; for (const t of tabs) { try { switchTab(t); } catch(e){ return false; } const el = document.getElementById('tab-'+t); if (!el) return false; if (t !== '_more' && !el.classList.contains('active')) return false; } return true; })()" }
      ]
    }
  ]
}

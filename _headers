# Global security headers on all responses
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(self), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://maps.googleapis.com https://cdnjs.cloudflare.com https://unpkg.com https://plausible.io https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com https://unpkg.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://tripai-backend.vercel.app https://autocomplete.travelpayouts.com https://en.wikipedia.org https://en.m.wikipedia.org https://commons.wikimedia.org https://maps.googleapis.com https://alnzqqlwqwxknxaxtawh.supabase.co https://api.github.com https://plausible.io https://cloudflareinsights.com; frame-src 'none'; object-src 'none'; base-uri 'self';

# Service Worker must never be cached — browsers need to detect updates immediately
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

# HTML pages — short cache, always revalidate
/*.html
  Cache-Control: no-cache

# Admin + internal pages — never index, never cache
/admin.html
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store

# Ticket files — cache aggressively (they never change)
/tickets/*
  Cache-Control: public, max-age=31536000, immutable
